# travel-buddy FastAPI backend base URL (e.g. http://localhost:8000)
VITE_BACKEND_API_URL=

# LLM API endpoint (OpenAI-compatible, e.g. https://api.openai.com/v1)
VITE_LLM_API_URL=

# ⚠️  WARNING: This key is bundled into the browser build and visible to anyone.
# This is acceptable for local dev/demo ONLY.
# Before any public deployment, move all LLM calls behind a backend proxy.
VITE_LLM_API_KEY=your_openai_api_key_here

# Google Maps JavaScript API key
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# Set to "true" to use mock data (no backend or LLM key required)
VITE_USE_MOCK=true
